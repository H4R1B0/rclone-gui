{
  "name": "rclone-gui",
  "version": "0.1.0",
  "description": "rclone 기반 멀티 클라우드 파일 매니저 GUI",
  "main": "dist-electron/main.js",
  "author": "rclone-gui",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
